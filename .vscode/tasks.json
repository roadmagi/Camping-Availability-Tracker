{
    // Auto-launches a Claude terminal when this folder is opened in VS Code.
    // First time, VS Code asks to "Allow Automatic Tasks in Folder" — click Allow.
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Launch Claude",
            "type": "shell",
            "command": "claude",
            "options": {
                "shell": {
                    "executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
                    "args": ["-ExecutionPolicy", "Bypass", "-NoExit", "-Command"]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": []
        }
    ]
}
